# 운영(EC2)용 환경변수 예시. EC2의 ~/bodeum/.env 로 복사한 뒤 실제 값으로 채운다.
# 이 파일(예시)만 Git에 올리고, 실제 값이 든 .env 는 절대 커밋하지 않는다.

SPRING_PROFILES_ACTIVE=prod

# --- DB: RDS MySQL ---
# 엔드포인트는 RDS 콘솔의 "엔드포인트" 값. localhost 아님에 주의.
DB_URL=jdbc:mysql://<RDS_ENDPOINT>:3306/bodeum?serverTimezone=UTC&characterEncoding=UTF-8
DB_USER=<RDS_MASTER_USER>
DB_PW=<RDS_PASSWORD>
# 운영에서는 절대 update/create 금지. prod 프로파일이 validate를 강제하므로 여기선 생략/무시됨.

# --- AI / OpenAI ---
OPENAI_API_KEY=

# 운영 Chroma 호스트는 application-prod.yml의 http://chroma로 고정한다.
# 항상 false로 유지한다. 전체 재색인은 Compose의 indexer 서비스가 true로 덮어쓴다.
AI_INDEXING_RUN_ONCE=false

# --- JWT ---
JWT_SECRET=<32바이트 이상의 랜덤 시크릿>
AUTH_ACCESS_TOKEN_TTL=1h
AUTH_REFRESH_TOKEN_TTL=14d

# --- 서비스 기본 URL (HTTPS 도메인) ---
BODEUM_BASE_URL=https://<YOUR_DOMAIN>
OAUTH_MOCK_ENABLED=false

# --- 카카오 OAuth ---
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=https://<YOUR_DOMAIN>/api/v1/auth/callback/kakao
KAKAO_SCOPE=
KAKAO_TOKEN_URI=
KAKAO_USER_INFO_URI=

# --- 네이버 OAuth ---
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
NAVER_REDIRECT_URI=https://<YOUR_DOMAIN>/api/v1/auth/callback/naver
NAVER_TOKEN_URI=
NAVER_USER_INFO_URI=

# --- AWS S3 (프로필 이미지 업로드) ---
AWS_S3_BUCKET=
AWS_S3_REGION=ap-northeast-2
AWS_ACCESS_KEY=
AWS_SECRET_KEY=
AWS_S3_PUBLIC_BASE_URL=
