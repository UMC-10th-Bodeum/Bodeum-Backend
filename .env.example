# 데이터베이스 연결
DB_URL=jdbc:mysql://localhost:3306/DB_NAME?serverTimezone=UTC&characterEncoding=UTF-8
DB_USER=root
DB_PW=DB_PASSWORD

JWT_SECRET=replace-with-at-least-32-byte-secret
AUTH_ACCESS_TOKEN_TTL=1h
AUTH_REFRESH_TOKEN_TTL=14d

BODEUM_BASE_URL=https://api.example.com
OAUTH_MOCK_ENABLED=false

KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=
KAKAO_SCOPE=
KAKAO_TOKEN_URI=
KAKAO_USER_INFO_URI=

NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
NAVER_REDIRECT_URI=
NAVER_TOKEN_URI=
NAVER_USER_INFO_URI=

# AWS S3 (프로필 이미지 업로드)
AWS_S3_BUCKET=
AWS_S3_REGION=ap-northeast-2
AWS_ACCESS_KEY=
AWS_SECRET_KEY=
# CloudFront 등 CDN을 앞단에 둘 경우 그 도메인. 비우면 표준 S3 URL 사용
AWS_S3_PUBLIC_BASE_URL=

# OpenAI
OPENAI_API_KEY=

# 평소에는 false. 전체 재색인 실행 시에만 true
AI_INDEXING_RUN_ONCE=false
